# Ambiente
NODE_ENV=development
PORT=8080

# Frontend autorizado para CORS. Em produção, troque pela URL real do front.
CORS_ORIGIN=http://localhost:5173

# Segurança
JWT_SECRET=troque-por-uma-chave-grande-e-secreta
JWT_EXPIRES_IN=7d

# Banco PostgreSQL local/cloud por URL.
DATABASE_URL=postgresql://empreende_user:empreende_pass@localhost:5432/empreende_plus

# Opcional: conexão Cloud SQL por Unix socket no Cloud Run.
# Use em produção quando conectar Cloud Run + Cloud SQL.
# CLOUD_SQL_CONNECTION_NAME=seu-projeto:southamerica-east1:empreende-plus-db
# INSTANCE_UNIX_SOCKET=/cloudsql/seu-projeto:southamerica-east1:empreende-plus-db
# PGUSER=empreende_user
# PGPASSWORD=empreende_pass
# PGDATABASE=empreende_plus
